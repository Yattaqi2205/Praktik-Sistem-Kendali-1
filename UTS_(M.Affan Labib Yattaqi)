>> % 1. Definisikan subsistem G1 dan G2
num1 = [1 1];       % s + 1
den1 = [1 3];       % s + 3
G1 = tf(num1, den1);

num2 = [1 0];       % s
den2 = [1 2 5];     % s^2 + 2s + 5
G2 = tf(num2, den2);

% 2. Hubungkan secara paralel
G_total = G1 + G2; % Bisa juga pakai: G_total = parallel(G1, G2);

% 3. Tampilkan fungsi transfer total di Command Window
disp('Fungsi Transfer Total (Paralel):');
G_total

% 4. Tampilkan grafik Bode dan Impulse
figure;
subplot(2,1,1);
bode(G_total);      % Menampilkan respon frekuensi
grid on;
title('Bode Plot - Sistem Paralel');

subplot(2,1,2);
impulse(G_total);   % Menampilkan respon terhadap sinyal impuls
grid on;
title('Impulse Response - Sistem Paralel');
