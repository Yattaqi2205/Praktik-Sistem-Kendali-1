>> % 1. Set nilai sembarang untuk k, c, dan m (Sesuai instruksi soal)
k = 10; 
c = 2;
m = 1;

% 2. Definisikan matriks sistem kontinu (A, B, C, D)
A = [0 1; -k/m -c/m];
B = [0; 1/m];
C = [1 0];
D = 0;

% 3. Buat model state-space kontinu
sys_cont = ss(A, B, C, D);

% 4. Tentukan Sample Time (misal 0.1 detik)
Ts = 0.1;

% 5. Diskritisasi menggunakan metode Zero-Order Hold (ZOH)
sys_disc = c2d(sys_cont, Ts, 'zoh');

% Menampilkan hasil matriks diskrit (Ad, Bd, Cd, Dd)
disp('Matriks Sistem Diskrit:');
sys_disc
