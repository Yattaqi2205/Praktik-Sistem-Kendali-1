>> disp(' ');
disp('=== SOAL 4: TIME RESPONSE (STEP RESPONSE) ===');

% Transfer function H(s) = (s + 1) / (s^2 - s + 3)
num4 = [1 1];
den4 = [1 -1 3];

H4 = tf(num4, den4);

% Time vector dari 0 sampai 10 detik
t = 0:0.01:10;

% Plot step response
figure;
step(H4, t);
grid on;
title('Step Response of H(s) = (s + 1) / (s^2 - s + 3)');
xlabel('Time (seconds)');
ylabel('Amplitude');
 
